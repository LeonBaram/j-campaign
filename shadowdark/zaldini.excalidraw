      "link": null,
      "locked": false,
      "text": "        SPELL ROLL OUTCOMES\n\nSpellcasting Checks:\n- Nat 20: 2x one numerical effect\n- Success: cast spell normally\n- Fail: spell fails, gone for today\n- Nat 1: spell fails, gone for today.\n         roll on Mishap Table.\n\nFocus Checks:\n- Nat 20: keep focusing\n- Success: keep focusing\n- Fail: spell is done, can recast\n- Nat 1: spell is done, gone for\ntoday.",
      "fontSize": 9.813953488372096,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "EW2Sddx_WUQM-0YHRal0-",
      "originalText": "        SPELL ROLL OUTCOMES\n\nSpellcasting Checks:\n- Nat 20: 2x one numerical effect\n- Success: cast spell normally\n- Fail: spell fails, gone for today\n- Nat 1: spell fails, gone for today.\n         roll on Mishap Table.\n\nFocus Checks:\n- Nat 20: keep focusing\n- Success: keep focusing\n- Fail: spell is done, can recast\n- Nat 1: spell is done, gone for today.",
      "autoResize": true,
      "lineHeight": 1.25
    },
