    {
      "id": "ZXD5ynramw49G0baFKT0J",
      "type": "text",
      "x": 573.2465846306281,
      "y": 983.7718310329138,
      "width": 104.38333129882812,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
