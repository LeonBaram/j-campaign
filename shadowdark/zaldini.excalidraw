      "boundElements": [],
      "updated": 1783828478949,
      "link": null,
      "locked": false,
      "text": "FREE CARRY\n- backpack\n- money: 1gp",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FREE CARRY\n- backpack\n- money: 1gp",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zJ4ByU-ymJZTCHPWS-AxL",
      "type": "text",
      "x": 949.0465838676886,
      "y": 1159.7718310329137,
      "width": 155.2834472656248,
      "height": 31.463520676249548,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1e",
      "roundness": null,
      "seed": 198993524,
      "version": 1461,
      "versionNonce": 813319540,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783828478949,
      "link": null,
      "locked": false,
      "text": "Benefit. All snakes regard you with a friendly attitude unless you do something to\nupset them. Once per day, you can throw the staff to the ground. It becomes a giant\nsnake for 5 rounds that obeys your mental commands. If the giant snake goes to 0 HP,\nit reverts into a staff.\n\nCurse. You have disadvantage on attacks and casting hostile spells targeting snakes.\n",
      "fontSize": 3.5958309344285198,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Benefit. All snakes regard you with a friendly attitude unless you do something to upset them. Once per day, you can throw the staff to the ground. It becomes a giant snake for 5 rounds that obeys your mental commands. If the giant snake goes to 0 HP, it reverts into a staff.\n\nCurse. You have disadvantage on attacks and casting hostile spells targeting snakes.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "9fZ-ePZAfRYYThM7ssipv",
      "type": "text",
      "x": 1334.5548486537784,
      "y": 1287.3636178597903,
      "width": 159.43645555614816,
      "height": 35.743736908274556,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1f",
      "roundness": null,
      "seed": 277889652,
      "version": 456,
      "versionNonce": 24737524,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783828478949,
      "link": null,
      "locked": false,
      "text": "Benefit. When you drink this potion, roll your class's hit points die.\nYou permanently gain that many HP.\n\nCurse. If you drink more than one Potion of Vitality in your lifetime,\nyou must pass a DC 18 Constitution check each time or die\ninstantly.",
      "fontSize": 4.765831587769941,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Benefit. When you drink this potion, roll your class's hit points die. You permanently gain that many HP.\n\nCurse. If you drink more than one Potion of Vitality in your lifetime, you must pass a DC 18 Constitution check each time or die instantly.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "x13YutaJKitnscTAuQtY7",
      "type": "text",
      "x": 1139.3552142820972,
      "y": 1286.3696565558903,
      "width": 160.98464053515514,
      "height": 30.646804254319946,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1g",
      "roundness": null,
      "seed": 295772404,
      "version": 490,
      "versionNonce": 513177716,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783828478949,
      "link": null,
      "locked": false,
      "text": "Benefit. This bag has an interdimensional space inside that can\nhold up to 10 gear slots.\n\nCurse. Placing this item inside another Bag of Holding or a\nPortable Hole destroys both items and all held inside them.",
      "fontSize": 4.903488680691191,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Benefit. This bag has an interdimensional space inside that can hold up to 10 gear slots.\n\nCurse. Placing this item inside another Bag of Holding or a Portable Hole destroys both items and all held inside them.",
      "autoResize": false,
      "lineHeight": 1.25
    },
