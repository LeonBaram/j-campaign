      "isDeleted": false,
      "boundElements": [],
      "updated": 1783828478949,
      "link": null,
      "locked": false,
      "text": "Benefit. If you serve this potion to an\nintelligent being and that being drinks it,\nthe imbiber permanently forgets one\nmemory of your choosing.",
      "fontSize": 8.21029912451359,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Benefit. If you serve this potion to an intelligent being and that being drinks it, the imbiber permanently forgets one memory of your choosing.",
      "autoResize": false,
      "lineHeight": 1.25
    }
  ],
